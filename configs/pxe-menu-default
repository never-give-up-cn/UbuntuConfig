UI vesamenu.c32
MENU TITLE PXE Multi-Boot - 192.168.1.14
MENU COLOR border 30;44 #ffffffff #00000000
MENU COLOR title 1;36;44 #ffffffff #00000000
MENU COLOR sel 7;37;44 #ffffffff #ee000000
MENU COLOR unsel 37;44 #ffffffff #00000000
TIMEOUT 300
DEFAULT local

LABEL local
    MENU LABEL ^1. Local Disk
    LOCALBOOT 0

LABEL ubuntu-desktop
    MENU LABEL ^2. Ubuntu 26.04 Desktop Live
    KERNEL vmlinuz-ubuntu-desktop
    APPEND initrd=initrd-ubuntu-desktop ip=dhcp netboot=nfs nfsroot=192.168.1.14:/srv/pxe/ubuntu-desktop rw --- quiet splash

LABEL ubuntu-server
    MENU LABEL ^3. Ubuntu 26.04 Server Live
    KERNEL vmlinuz-ubuntu-server
    APPEND initrd=initrd-ubuntu-server ip=dhcp netboot=nfs nfsroot=192.168.1.14:/srv/pxe/ubuntu-server rw --- quiet splash

LABEL winpe
    MENU LABEL ^4. Windows PE (ARM64)
    KERNEL wimboot
    APPEND initrd=@bootmgfw.efi=efi/bootmgfw.efi
            initrd=@bootmgr.efi=efi/bootmgr.efi
            initrd=@boot.sdi=boot.sdi
            initrd=@boot.wim=boot.wim

LABEL win11-install
    MENU LABEL ^5. Windows 11 Install (ARM64)
    KERNEL wimboot
    APPEND initrd=@bootmgfw.efi=efi/bootmgfw.efi
            initrd=@bootmgr.efi=efi/bootmgr.efi
            initrd=@boot.sdi=boot.sdi
            initrd=@boot.wim=boot.wim

LABEL ipxe
    MENU LABEL ^6. iPXE Shell
    KERNEL ipxe.pxe

LABEL memtest
    MENU LABEL ^7. Memtest86+
    KERNEL memtest86+

LABEL shutdown
    MENU LABEL ^8. Shutdown Server
    COM32 poweroff.c32

LABEL reboot
    MENU LABEL ^9. Reboot
    COM32 reboot.c32

LABEL iscsi-ubuntu
    MENU LABEL ^0. Boot from iSCSI (Persistent Ubuntu)
    KERNEL ipxe.pxe
    APPEND dhcp && chain tftp://192.168.1.14/iscsi-boot.ipxe

LABEL iscsi-windows
    MENU LABEL ^W. Boot from iSCSI (Windows 11)
    KERNEL ipxe.pxe
    APPEND dhcp && sanboot iscsi:192.168.1.14::::iqn.2026-07.local.pxe:windows11
